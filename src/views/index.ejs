<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Matthew Thompson | Zenith Tutoring</title>

    <meta name="description"
        content="Private tutor in Southampton, Winchester and Romsey. GCSE, IGCSE, A-Level, Functional Skills and Degree Level support in English, Psychology and Humanities." />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <!-- Font Awesome -->
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js"
        crossorigin="anonymous"></script>

    <style>
        /* =========================================
        MAIN BACKGROUND
        ========================================= */

        .animated-bg {
            position: fixed;
            inset: 0;
            overflow: hidden;
            z-index: -1;
            background:
                radial-gradient(circle at top left,
                rgba(37,99,235,0.15),
                transparent 35%),

                radial-gradient(circle at bottom right,
                rgba(124,58,237,0.18),
                transparent 35%),

                #07111f;
        }

        /* =========================================
        GLOWING BLOBS
        ========================================= */

        .gradient-sphere {
            position: absolute;
            border-radius: 50%;
            filter: blur(300px);
            opacity: 0.55;
            mix-blend-mode: screen;

            will-change: transform;

            animation-timing-function: ease-in-out;
            animation-iteration-count: infinite;
        }

        /* BLUE BLOB */

        .sphere-1 {
            width: clamp(320px, 60vw, 900px);
            height: clamp(320px, 60vw, 900px);

            background: #2563eb;

            top: clamp(-300px, -20vw, -120px);
            left: clamp(-300px, -20vw, -120px);

            animation: floatOne 24s ease-in-out infinite;
        }

        /* PURPLE BLOB */

        .sphere-2 {
            width: clamp(300px, 55vw, 850px);
            height: clamp(300px, 55vw, 850px);

            background: #7c3aed;

            bottom: clamp(-320px, -18vw, -100px);
            right: clamp(-260px, -16vw, -80px);

            animation: floatTwo 28s ease-in-out infinite;
        }

        /* CYAN BLOB */

        .sphere-3 {
            width: clamp(260px, 45vw, 700px);
            height: clamp(260px, 45vw, 700px);

            background: #06b6d4;

            top: 20%;
            left: 45%;

            animation: floatThree 22s ease-in-out infinite;
        }
        /* =========================================
        BLOB ANIMATIONS
        ========================================= */

        @keyframes floatOne {

            0% {
                transform: translate3d(0,0,0) scale(1);
            }

            25% {
                transform: translate3d(160px,120px,0) scale(1.12);
            }

            50% {
                transform: translate3d(80px,260px,0) scale(1.2);
            }

            75% {
                transform: translate3d(-140px,140px,0) scale(1.08);
            }

            100% {
                transform: translate3d(0,0,0) scale(1);
            }
        }

        @keyframes floatTwo {

            0% {
                transform: translate3d(0,0,0) scale(1);
            }

            25% {
                transform: translate3d(-180px,-120px,0) scale(1.1);
            }

            50% {
                transform: translate3d(-60px,-260px,0) scale(1.18);
            }

            75% {
                transform: translate3d(140px,-100px,0) scale(1.05);
            }

            100% {
                transform: translate3d(0,0,0) scale(1);
            }
        }

        @keyframes floatThree {

            0% {
                transform: translate3d(0,0,0) scale(1);
            }

            25% {
                transform: translate3d(-180px,120px,0) scale(1.08);
            }

            50% {
                transform: translate3d(120px,-180px,0) scale(1.15);
            }

            75% {
                transform: translate3d(200px,80px,0) scale(1.06);
            }

            100% {
                transform: translate3d(0,0,0) scale(1);
            }
        }

        /* =========================================
        PARTICLES
        ========================================= */

        .particles {
            position: absolute;
            inset: 0;
            overflow: hidden;
        }

        .particles span {
            position: absolute;
            border-radius: 50%;
            filter: blur(2px);

            opacity: 0.7;

            animation-timing-function: linear;
            animation-iteration-count: infinite;

            will-change: transform;
        }

        /* BLUE */

        .particles span:nth-child(1) {
            width: 14px;
            height: 14px;
            background: rgba(37,99,235,0.9);

            left: 8%;
            top: 80%;

            box-shadow: 0 0 20px rgba(37,99,235,0.8);

            animation: particleOne 22s infinite;
        }

        .particles span:nth-child(2) {
            width: 10px;
            height: 10px;
            background: rgba(59,130,246,0.8);

            left: 20%;
            top: 10%;

            box-shadow: 0 0 16px rgba(59,130,246,0.8);

            animation: particleTwo 18s infinite;
        }

        /* PURPLE */

        .particles span:nth-child(3) {
            width: 16px;
            height: 16px;
            background: rgba(124,58,237,0.9);

            left: 75%;
            top: 70%;

            box-shadow: 0 0 22px rgba(124,58,237,0.9);

            animation: particleThree 26s infinite;
        }

        .particles span:nth-child(4) {
            width: 12px;
            height: 12px;
            background: rgba(168,85,247,0.8);

            left: 90%;
            top: 20%;

            box-shadow: 0 0 18px rgba(168,85,247,0.8);

            animation: particleFour 20s infinite;
        }

        /* CYAN */

        .particles span:nth-child(5) {
            width: 18px;
            height: 18px;
            background: rgba(6,182,212,0.9);

            left: 45%;
            top: 85%;

            box-shadow: 0 0 24px rgba(6,182,212,0.8);

            animation: particleFive 24s infinite;
        }

        .particles span:nth-child(6) {
            width: 11px;
            height: 11px;
            background: rgba(34,211,238,0.85);

            left: 55%;
            top: 15%;

            box-shadow: 0 0 18px rgba(34,211,238,0.8);

            animation: particleSix 17s infinite;
        }

        /* WHITE LIGHTS */

        .particles span:nth-child(7) {
            width: 8px;
            height: 8px;
            background: rgba(255,255,255,0.7);

            left: 35%;
            top: 50%;

            box-shadow: 0 0 14px rgba(255,255,255,0.8);

            animation: particleSeven 28s infinite;
        }

        .particles span:nth-child(8) {
            width: 7px;
            height: 7px;
            background: rgba(255,255,255,0.6);

            left: 82%;
            top: 40%;

            box-shadow: 0 0 12px rgba(255,255,255,0.7);

            animation: particleEight 30s infinite;
        }

        /* =========================================
        PARTICLE ANIMATIONS
        ========================================= */

        @keyframes particleOne {

            0% {
                transform: translate(0,0) scale(1);
            }

            25% {
                transform: translate(140px,-220px) scale(1.3);
            }

            50% {
                transform: translate(320px,-80px) scale(0.8);
            }

            75% {
                transform: translate(180px,160px) scale(1.2);
            }

            100% {
                transform: translate(0,0) scale(1);
            }
        }

        @keyframes particleTwo {

            0% {
                transform: translate(0,0);
            }

            25% {
                transform: translate(-100px,180px);
            }

            50% {
                transform: translate(120px,320px);
            }

            75% {
                transform: translate(220px,120px);
            }

            100% {
                transform: translate(0,0);
            }
        }

        @keyframes particleThree {

            0% {
                transform: translate(0,0) scale(1);
            }

            20% {
                transform: translate(-180px,-120px) scale(1.2);
            }

            40% {
                transform: translate(-320px,80px) scale(0.9);
            }

            60% {
                transform: translate(-120px,260px) scale(1.3);
            }

            80% {
                transform: translate(80px,120px) scale(1);
            }

            100% {
                transform: translate(0,0) scale(1);
            }
        }

        @keyframes particleFour {

            0% {
                transform: translate(0,0);
            }

            25% {
                transform: translate(-240px,120px);
            }

            50% {
                transform: translate(-140px,340px);
            }

            75% {
                transform: translate(80px,160px);
            }

            100% {
                transform: translate(0,0);
            }
        }

        @keyframes particleFive {

            0% {
                transform: translate(0,0) scale(1);
            }

            25% {
                transform: translate(220px,-140px) scale(1.25);
            }

            50% {
                transform: translate(-80px,-320px) scale(0.8);
            }

            75% {
                transform: translate(-240px,-120px) scale(1.1);
            }

            100% {
                transform: translate(0,0) scale(1);
            }
        }

        @keyframes particleSix {

            0% {
                transform: translate(0,0);
            }

            25% {
                transform: translate(180px,80px);
            }

            50% {
                transform: translate(260px,260px);
            }

            75% {
                transform: translate(-120px,180px);
            }

            100% {
                transform: translate(0,0);
            }
        }

        @keyframes particleSeven {

            0% {
                transform: translate(0,0);
                opacity: 0.4;
            }

            50% {
                transform: translate(300px,-180px);
                opacity: 1;
            }

            100% {
                transform: translate(0,0);
                opacity: 0.4;
            }
        }

        @keyframes particleEight {

            0% {
                transform: translate(0,0);
                opacity: 0.5;
            }

            50% {
                transform: translate(-280px,220px);
                opacity: 1;
            }

            100% {
                transform: translate(0,0);
                opacity: 0.5;
            }
        }


        /* GLASS EFFECT */

        .glass-card {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.08);
            backdrop-filter: blur(16px);
            border-radius: 28px;
        }

        /* REVEAL ANIMATIONS */

        .reveal {
            opacity: 0;
            transform: translateY(60px);
            transition: all 1s ease;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* Optional Glass Effect For Sections */

        .glass-card {
            background: rgba(255,255,255,0.06);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 28px;
        }

        /* Smooth Fade In */

        .fade-up {
            opacity: 0;
            transform: translateY(40px);
            animation: fadeUp 1s ease forwards;
        }

        @keyframes fadeUp {

            to {
                opacity: 1;
                transform: translateY(0);
            }

        }

        :root {
            --bg: #07111f;
            --card: rgba(255,255,255,0.06);
            --text: #f5f7fb;
            --muted: #b8c2d0;
            --primary: #6ea8fe;
            --secondary: #8b5cf6;
            --border: rgba(255,255,255,0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: #07111f;
            color: var(--text);
            overflow-x: hidden;
            position: relative;
        }

        a {
            text-decoration: none;
        }


        /* Navbar */

        .navbar {
            background: rgba(8, 15, 28, 0.7);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid rgba(255,255,255,0.08);
            padding: 18px 0;
            transition: 0.3s ease;
        }

        .navbar-brand {
            color: white;
            font-size: 1.4rem;
            font-weight: 700;
        }

        .nav-link {
            color: rgba(255,255,255,0.8);
            margin-left: 20px;
            font-weight: 500;
            transition: 0.3s ease;
        }

        .nav-link:hover {
            color: white;
            transform: translateY(-2px);
        }

        /* Hero */

        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 10px 18px;
            border-radius: 100px;
            margin-bottom: 25px;
            animation: fadeUp 1s ease;
        }

        .hero-badge i {
            color: #60a5fa;
        }

        .hero h1 {
            font-size: 5rem;
            line-height: 1.05;
            font-weight: 700;
            font-family: 'Playfair Display', serif;
            margin-bottom: 25px;
            animation: fadeUp 1.1s ease;
        }

        .hero h1 span {
            color: #7dd3fc;
        }

        .hero p {
            font-size: 1.2rem;
            color: var(--muted);
            max-width: 700px;
            line-height: 1.8;
            animation: fadeUp 1.2s ease;
        }

        .hero-buttons {
            margin-top: 40px;
            display: flex;
            gap: 18px;
            flex-wrap: wrap;
            animation: fadeUp 1.3s ease;
        }

        .btn-main {
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            border: none;
            color: white;
            padding: 16px 30px;
            border-radius: 14px;
            font-weight: 600;
            transition: 0.35s ease;
            box-shadow: 0 10px 40px rgba(59,130,246,0.3);
        }

        .btn-main:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 50px rgba(59,130,246,0.45);
        }

        .btn-outline-custom {
            border: 1px solid rgba(255,255,255,0.15);
            background: rgba(255,255,255,0.05);
            color: white;
            padding: 16px 30px;
            border-radius: 14px;
            transition: 0.35s ease;
        }

        .btn-outline-custom:hover {
            background: rgba(255,255,255,0.12);
            transform: translateY(-5px);
        }

        /* Glass Cards */

        .glass-card {
            background: var(--card);
            border: 1px solid var(--border);
            backdrop-filter: blur(14px);
            border-radius: 28px;
            padding: 35px;
            transition: 0.4s ease;
            height: 100%;
        }

        .glass-card:hover {
            transform: translateY(-10px);
            border-color: rgba(255,255,255,0.2);
            box-shadow: 0 25px 60px rgba(0,0,0,0.25);
        }

        .glass-card i {
            font-size: 2.5rem;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #60a5fa, #8b5cf6);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* Sections */

        section {
            padding: 120px 0;
        }

        .section-title {
            text-align: center;
            margin-bottom: 70px;
        }

        .section-title h2 {
            font-size: 3rem;
            font-family: 'Playfair Display', serif;
            margin-bottom: 20px;
        }

        .section-title p {
            color: var(--muted);
            max-width: 700px;
            margin: auto;
            line-height: 1.8;
        }

        /* Subject Pills */

        .subject-pills {
            display: flex;
            flex-wrap: wrap;
            gap: 18px;
            justify-content: center;
        }

        .subject-pill {
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            padding: 16px 24px;
            border-radius: 100px;
            transition: 0.35s ease;
        }

        .subject-pill:hover {
            transform: scale(1.08);
            background: linear-gradient(135deg, #2563eb, #7c3aed);
        }


        /* Table */

        #pricing .table {
            --bs-table-bg: transparent;
            --bs-table-striped-bg: transparent;
            --bs-table-hover-bg: rgba(255,255,255,0.04);
            --bs-table-border-color: rgba(255,255,255,0.08);
            color: white;
        }

        #pricing .table th,
        #pricing .table td {
            color: #fff !important;
        }

        .pricing-table {
            width: 100%;
            border-collapse: collapse;
            color: white;
        }

        .pricing-table th,
        .pricing-table td {
            padding: 1rem;
            background: transparent;
        }

        .pricing-table th {
            text-align: left;
            border-bottom: 1px solid rgba(255,255,255,0.15);
        }

        .pricing-table td {
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

        .pricing-table tr:last-child td {
            border-bottom: none;
        }

        /* Contact */

        .contact-box {
            text-align: center;
            padding: 60px;
        }

        .contact-box h2 {
            font-size: 3rem;
            margin-bottom: 20px;
            font-family: 'Playfair Display', serif;
        }

        .contact-box p {
            color: var(--muted);
            margin-bottom: 35px;
        }

        footer {
            padding: 40px 0;
            border-top: 1px solid rgba(255,255,255,0.08);
            text-align: center;
            color: rgba(255,255,255,0.6);
        }

        .socials {
            margin-bottom: 20px;
        }

        .socials a {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: white;
            margin: 0 8px;
            transition: 0.35s ease;
        }

        .socials a:hover {
            transform: translateY(-6px);
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        }

        /* Animations */

        @keyframes fadeUp {

            from {
                opacity: 0;
                transform: translateY(40px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .reveal {
            opacity: 0;
            transform: translateY(60px);
            transition: all 1s ease;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* Responsive */

        @media(max-width: 992px) {

            .hero h1 {
                font-size: 3.5rem;
            }

            .section-title h2 {
                font-size: 2.3rem;
            }
        }

        @media(max-width: 768px) {

            .hero {
                text-align: center;
                padding-top: 100px;
            }

            .hero h1 {
                font-size: 2.8rem;
            }

            .hero-buttons {
                justify-content: center;
            }

            .contact-box {
                padding: 40px 25px;
            }
        }

        .review-stars {
            color: #fbbf24;
            font-size: 1.1rem;
            letter-spacing: 2px;
            margin-bottom: 1rem;
        }

    </style>
</head>

